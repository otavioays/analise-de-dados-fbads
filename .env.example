# Supabase project settings. Keep the service role key server-side only.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# Comma-separated origins allowed to send events.
# Use the exact production domain and localhost while developing.
TRACKING_ALLOWED_ORIGINS=http://localhost:3000,https://sualoja.com.br
